# Copy this file to deploy.env and fill in your values.
# deploy.env is gitignored — never commit it.

# AWS SSO profile name (from ~/.aws/config)
PROFILE="YOUR_ACCOUNT_ID_Standard_PowerUser"

# AWS region
REGION="us-west-2"

# S3 bucket for deploying app files (create once, reuse)
# aws s3 mb s3://kali-gtm-hub-deploy --region us-west-2 --profile $PROFILE
BUCKET="kali-gtm-hub-deploy"

# EC2 security group ID
# aws ec2 create-security-group --group-name kali-gtm-hub-sg --description "GTM Hub" --profile $PROFILE --region $REGION
SG_ID="sg-xxxxxxxxxxxxxxxxx"

# Tag applied to EC2 instances (used to find and terminate old ones on redeploy)
TAG_NAME="kali-gtm-hub"

# EC2 key pair name (for emergency SSH access)
# aws ec2 create-key-pair --key-name kali-gtm-hub-key --profile $PROFILE --region $REGION --query KeyMaterial --output text > ~/.ssh/kali-gtm-hub-key.pem
KEY_NAME="kali-gtm-hub-key"

# Elastic IP allocation ID (for a permanent URL across redeploys)
# aws ec2 allocate-address --domain vpc --tag-specifications 'ResourceType=elastic-ip,Tags=[{Key=Name,Value=kali-gtm-hub-eip},{Key=owner,Value=kali}]' --profile $PROFILE --region $REGION
EIP_ALLOC="eipalloc-xxxxxxxxxxxxxxxxx"

# CloudFront distribution domain (HTTPS terminated by CloudFront — no certs on EC2)
# CloudFront origin: EC2 public DNS derived from EIP, e.g. ec2-44-230-217-150.us-west-2.compute.amazonaws.com
# That hostname is stable — always resolves to the EIP regardless of which instance holds it.
DOMAIN="xxxxxxxxxxxx.cloudfront.net"

# Google OAuth credentials (from console.cloud.google.com)
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"

# Flask session signing key — generate with: openssl rand -hex 32
# Required in production. Must be the same across all gunicorn workers.
SECRET_KEY="replace-with-openssl-rand-hex-32-output"

# Public URL of the frontend (no trailing slash)
# In production this is your CloudFront domain: https://xxxxxxxxxxxx.cloudfront.net
# In local dev this defaults to http://localhost:5173 automatically
FRONTEND_URL="https://xxxxxxxxxxxx.cloudfront.net"

# Salesforce connected app credentials (server-side only — never use VITE_ prefix)
# Obtain from: Setup > App Manager > your connected app
SALESFORCE_INSTANCE_URL="https://twlo.my.salesforce.com"
SALESFORCE_CLIENT_ID="your-salesforce-client-id"
SALESFORCE_CLIENT_SECRET="your-salesforce-client-secret"
SALESFORCE_REFRESH_TOKEN="your-salesforce-refresh-token"
SALESFORCE_ACCESS_TOKEN="your-salesforce-initial-access-token"

# ── Customer Profiler ────────────────────────────────────────────────────────
# OpenAI API key — https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-proj-..."

# Twilio credentials (Account SID + Auth Token from console.twilio.com)
TWILIO_ACCOUNT_SID="ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
TWILIO_AUTH_TOKEN="your-auth-token"

# Twilio number for outbound SMS (US team)
TWILIO_SMS_FROM="+1xxxxxxxxxx"

# Twilio WhatsApp sandbox number (LATAM team)
TWILIO_WHATSAPP_FROM="+14155238886"
